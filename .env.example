# Ignis configuration -- source of truth. Copy to .env and adjust.

# --- TimescaleDB (single lab store) ---
LOCAL_DB_HOST=localhost
LOCAL_DB_PORT=5432
LOCAL_DB_NAME=ignis
LOCAL_DB_USER=ignis
LOCAL_DB_PASSWORD=ignis

# --- Redis / Celery (engine train/detect tasks) ---
REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=        # defaults to REDIS_URL
# CELERY_RESULT_BACKEND=    # defaults to REDIS_URL

# --- NILM scheduling / detection (engine) ---
NILM_TRAINING_INTERVAL_HOURS=24
NILM_DETECTION_INTERVAL_MINUTES=5
# NILM_DETECTION_PERIOD_HOURS=     # empty = all history
NILM_WINDOW_SIZE_MINUTES=10
NILM_MIN_POWER_THRESHOLD=15
NILM_MIN_DURATION_SECONDS=30

# --- NILM model (engine) ---
NILM_MODEL_PATH=models
# Window length in grid points. 99 x 30s ~= 50 min (matched to an appliance
# cycle). NOT 599 (that was Linkya's 1 Hz value = 5h on a 30s grid -> drowns
# short cycles; see docs/nilm-imbalance.md).
NILM_SEQUENCE_LENGTH=99
NILM_BATCH_SIZE=32
NILM_EPOCHS=50
NILM_LEARNING_RATE=0.001
NILM_VALIDATION_SPLIT=0.2
NILM_MODEL_TYPE=gru
NILM_DETECT_STATES=true
# USE_GPU=auto                      # true / false / auto

# --- NILM targets (Meross mss315 plugs with W ground truth) ---
NILM_APPLIANCES=four,lave_linge,lave_vaisselle,pc,television,smart_plug

# --- Home Assistant ingestion (MQTT-push via mqtt_statestream) ---
# Requires HA configured with:
#   mqtt_statestream:
#     base_topic: statestream
#     publish_attributes: false
# Point this at YOUR HA / MQTT broker host (IP or hostname).
MQTT_HOST=home-assistant.local
MQTT_PORT=1883
# Broker requires auth if allow_anonymous false. Set these in .env (never commit).
# If the broker runs in Docker, publish the port on your LAN (bind to the LAN IP,
# not 0.0.0.0), e.g. compose: ports: ["<lan-ip>:1883:1883"]
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_STATESTREAM_PREFIX=statestream
# Your Linky aggregate (apparent power, VA) entity id.
HA_AGGREGATE_ENTITY=sensor.puissance_generale
MEROSS_DEVICE_TAG=mss315
INGEST_GRID_SECONDS=30

# SSH to the HA box for history backfill (runs sqlite3 in the HA container).
HA_SSH_USER=pi
# HA_SSH_HOST=                       # defaults to MQTT_HOST when unset
