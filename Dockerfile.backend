# Admin console + portfolio API. Light: FastAPI + psycopg, no TensorFlow.
FROM python:3.12-slim

ENV PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

# engine brings psycopg (DB reads); backend brings fastapi/uvicorn. No TF.
COPY pyproject.toml README.md ./
COPY src/ ./src/
RUN pip install --upgrade pip && pip install ".[engine,backend]"

EXPOSE 8001
CMD ["uvicorn", "ignis.backend.app:app", "--host", "0.0.0.0", "--port", "8001"]
